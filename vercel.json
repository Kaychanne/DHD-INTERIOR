{
    "version": 2,
    "framework": null,
    "builds": [
        { "src": "api/index.php", "use": "vercel-php@0.6.0" }
    ],
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}