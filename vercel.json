{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0",
            "includeFiles": [
                "app/**",
                "bootstrap/**",
                "config/**",
                "database/**",
                "public/**",
                "resources/**",
                "routes/**",
                "vendor/**"
            ]
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}